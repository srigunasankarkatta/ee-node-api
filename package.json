{
  "name": "equity-eyes",
  "version": "1.0.0",
  "description": "Equity Eyes - Stock & Market Data Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo:all",
    "db:seed": "sequelize-cli db:seed:all",
    "db:seed:undo": "sequelize-cli db:seed:undo:all",
    "db:drop": "node scripts/dropAllTables.js",
    "db:fresh": "node scripts/dropAllTables.js && sequelize-cli db:migrate && sequelize-cli db:seed:all",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop equity-eyes",
    "pm2:restart": "pm2 restart equity-eyes",
    "pm2:logs": "pm2 logs equity-eyes",
    "admin:install": "npm install --prefix admin",
    "admin:dev": "npm run dev --prefix admin",
    "admin:build": "npm run build --prefix admin"
  },
  "keywords": [
    "equity",
    "stocks",
    "finance",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.2",
    "bcryptjs": "^3.0.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "mysql2": "^3.22.5",
    "node-cron": "^4.4.1",
    "sequelize": "^6.37.8",
    "uuid": "^14.0.1",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "sequelize-cli": "^6.6.5",
    "xlsx": "^0.18.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
